# --- LLM ---
# Which backend to use: "aistudio" (local dev, Google AI Studio API key) or "vertex" (Cloud Run / GCP service account auth)
LLM_BACKEND=aistudio
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_MODEL_HEAVY=gemini-flash-latest

# --- GCP ---
GCP_PROJECT_ID=
GCP_REGION=asia-south1

# --- Persistence (MongoDB, used in later phases) ---
MONGODB_URI=
MONGODB_DB=lexguard

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
MAX_DOC_BYTES=10485760
MAX_REQUEST_BYTES=12582912
MAX_CLAUSES_PER_DOC=200
RATE_LIMIT_PER_MINUTE=30
ALLOWED_ORIGINS=*
